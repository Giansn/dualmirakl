# Copy to .env and fill in values

# ── Paths ─────────────────────────────────────────────────────────────────────
HF_HOME=/per.volume/huggingface
HF_TOKEN=                        # HuggingFace token (needed for gated models)
DUALMIRAKL_ROOT=/per.volume/dualmirakl

# ── vLLM endpoints ───────────────────────────────────────────────────────────
AUTHORITY_URL=http://localhost:8000/v1
SWARM_URL=http://localhost:8001/v1
GATEWAY_URL=http://localhost:9000/v1

# ── Ports (override for multi-instance) ──────────────────────────────────────
AUTHORITY_PORT=8000
SWARM_PORT=8001
GATEWAY_PORT=9000

# ── GPU assignment ───────────────────────────────────────────────────────────
AUTHORITY_GPU=0
SWARM_GPU=1

# ── Backend mapping (which model slot serves which role) ─────────────────────
BACKEND_ANALYST=authority        # observer_a, observer_b → GPU 0
BACKEND_ENVIRONMENT=authority    # environment agent → GPU 0 (balances load)
BACKEND_PERSONA=swarm            # participant agents → GPU 1

# ── Simulation parameters (tuned for throughput) ─────────────────────────────
SIM_N_TICKS=12
SIM_N_PARTICIPANTS=4
SIM_OBSERVER_K=4               # every 4 ticks — reduces 2 sequential observer calls
SIM_ALPHA=0.15                 # smoother EMA — less noise, cleaner trajectories
SIM_HISTORY_WINDOW=4
SIM_MAX_TOKENS=192             # agent outputs are action descriptions, not essays
SIM_SEED=42
INTERVENTION_THRESHOLD=0.72
PERSONA_SUMMARY_INTERVAL=10
EMBED_BATCH_SIZE=16

# ── Embedding model ──────────────────────────────────────────────────────────
SIM_EMBED_MODEL=                 # defaults to $HF_HOME/hub/e5-small-v2

# ── FLAME GPU 2 (optional, requires 3rd GPU) ──────────────────────────────
# Set FLAME_ENABLED=1 to activate population dynamics on a third GPU.
# dualmirakl operates normally without this — FLAME is an optional amplifier.
# When FLAME boots, W&B and Optuna are auto-configured if installed.
FLAME_ENABLED=0
FLAME_GPU=2
FLAME_N_POPULATION=10000
FLAME_INTERACTION_RADIUS=10.0
FLAME_KAPPA=0.1                  # peer coupling (0=independent, >0=conformity)
FLAME_INFLUENCER_WEIGHT=5.0
FLAME_DRIFT_SIGMA=0.01
FLAME_SUB_STEPS=10               # FLAME steps per dualmirakl tick

# ── Tracking & Optimization (auto-enabled when FLAME boots) ───────────────
# W&B: experiment tracking. Set project name to enable. Ignored if wandb not installed.
WANDB_PROJECT=                   # e.g. "dualmirakl" — empty = disabled
WANDB_ENTITY=                   # team/user — empty = personal default
WANDB_MODE=online               # online|offline|disabled

# Optuna: Bayesian optimization. Auto-configures when FLAME boots.
OPTUNA_STORAGE=                  # e.g. "sqlite:///optuna.db" — empty = in-memory
OPTUNA_STUDY_PREFIX=dualmirakl   # study name prefix
OPTUNA_DASHBOARD_PORT=8080       # optuna-dashboard port (if installed)

# ── Output ───────────────────────────────────────────────────────────────────
SIM_OUTPUT_DIR=data
