# =============================================================================
# Authority slot — Mistral Nemo Instruct 12B FP8
# HF: https://huggingface.co/neuralmagic/Mistral-Nemo-Instruct-2407-FP8
# Arch: Mistral Nemo 12B, FP8 quantized, 128k context (capped to 8K for sim)
# VRAM: ~12 GB model weight → 20 GB free for KV-Cache on RTX PRO 4500 (32 GB)
# =============================================================================

# -- Model path ---------------------------------------------------------------
MODEL=${HF_HOME:-/per.volume/huggingface}/hub/mistral-nemo-instruct-fp8

# -- HuggingFace repo (used by pull_models.sh) --------------------------------
AUTHORITY_HF_REPO=neuralmagic/Mistral-Nemo-Instruct-2407-FP8

# -- Quantization (FP8 auto-detected from checkpoint) ------------------------
QUANT_FLAGS="--dtype auto"

# -- vLLM flags (tuned for simulation) ----------------------------------------
# Context: observer prompts ~2K, environment DDA prompts ~1K -> 8K is plenty
# Prefix caching: agents share system prompts -> reuses KV cache -> ~30% faster
# Chunked prefill: interleaves prefill/decode -> better GPU utilization under load
# Concurrency: 12 seqs — environment (N sequential) + observers (2 sequential)
# gpu-mem 0.90: leaves 3.2 GB headroom for CUDA overhead
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=12
EXTRA_ENV=""
EXTRA_FLAGS="--enable-prefix-caching --enable-chunked-prefill"
