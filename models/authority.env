# =============================================================================
# Authority slot — model variables
# Source: sagea-ai/sage-reasoning-32b (placeholder — model not yet downloaded)
# HF: https://huggingface.co/sagea-ai/sage-reasoning-32b
# Arch: Qwen2.5-32B finetune, BF16, 128k context, hybrid reasoning
# VRAM: ~16 GB with INT4 | ~32 GB BF16 (does not fit unquantized)
# =============================================================================

# ── Model path ────────────────────────────────────────────────────────────────
MODEL=""
# MODEL=/per.volume/huggingface/hub/sage-reasoning-32b   # uncomment when downloaded

# ── Quantization (BF16 base — needs runtime INT4 to fit 32 GB) ───────────────
QUANT_FLAGS="--quantization bitsandbytes --load-format bitsandbytes --dtype float16"
# When AWQ version is available:
# QUANT_FLAGS="--quantization awq --dtype auto"

# ── vLLM flags (from HF model card) ──────────────────────────────────────────
MAX_MODEL_LEN=32768          # model supports 128k; cap at 32k for VRAM budget
MAX_NUM_SEQS=8
EXTRA_ENV=""                 # no special env vars needed for this model
EXTRA_FLAGS=""               # no reasoning parser needed (handled by chat template)
