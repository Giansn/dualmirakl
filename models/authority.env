# =============================================================================
# Authority slot — model variables (tuned for simulation throughput)
# Source: sagea-ai/sage-reasoning-32b (placeholder — model not yet downloaded)
# HF: https://huggingface.co/sagea-ai/sage-reasoning-32b
# Arch: Qwen2.5-32B finetune, BF16, 128k context, hybrid reasoning
# VRAM: ~16 GB with INT4 | ~32 GB BF16 (does not fit unquantized)
# =============================================================================

# ── Model path ────────────────────────────────────────────────────────────────
MODEL=""
# MODEL=/per.volume/huggingface/hub/sage-reasoning-32b   # uncomment when downloaded

# ── HuggingFace repo (used by pull_models.sh) ─────────────────────────────────
AUTHORITY_HF_REPO=""
# AUTHORITY_HF_REPO=sagea-ai/sage-reasoning-32b         # uncomment to enable auto-pull

# ── Quantization (BF16 base — needs runtime INT4 to fit 32 GB) ───────────────
QUANT_FLAGS="--quantization bitsandbytes --load-format bitsandbytes --dtype float16"
# When AWQ version is available:
# QUANT_FLAGS="--quantization awq --dtype auto"

# ── vLLM flags (tuned for simulation) ──────────────────────────────────────────
# Context: observer prompts ~2K max, agent calls ~1.5K → 8K is plenty
# Prefix caching: agents share system prompts → reuses KV cache → ~30% faster
# Chunked prefill: interleaves prefill/decode → better GPU utilization under load
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=8
EXTRA_ENV=""
EXTRA_FLAGS="--enable-prefix-caching --enable-chunked-prefill"
