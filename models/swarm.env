# =============================================================================
# Swarm slot — model variables
# Source: nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4
# HF: https://huggingface.co/nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4
# Arch: Nemotron-H hybrid (Mamba+MoE), 30B/3B-active, NVFP4+FP8-KV
# VRAM: ~15 GB | Context: up to 1M (capped at 32k below for VRAM budget)
# vLLM cookbook: https://github.com/NVIDIA-NeMo/Nemotron/blob/main/usage-cookbook/Nemotron-3-Nano/vllm_cookbook.ipynb
# =============================================================================

# ── Model path ────────────────────────────────────────────────────────────────
MODEL=/per.volume/huggingface/hub/nemotron-nano-30b

# ── Quantization (NVFP4 auto-detected from hf_quant_config.json) ─────────────
QUANT_FLAGS="--kv-cache-dtype fp8 --dtype auto"

# ── vLLM flags (from HF model card) ──────────────────────────────────────────
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8

# Custom reasoning parser (file ships with the model weights)
EXTRA_FLAGS="--enable-auto-tool-choice --tool-call-parser qwen3_coder --reasoning-parser-plugin /per.volume/huggingface/hub/nemotron-nano-30b/nano_v3_reasoning_parser.py --reasoning-parser nano_v3 --enforce-eager"

# Required env vars for NVFP4 MoE kernel (from HF model card)
EXTRA_ENV="VLLM_USE_FLASHINFER_MOE_FP4=1 VLLM_FLASHINFER_MOE_BACKEND=throughput PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True PYTORCH_ALLOC_CONF=expandable_segments:True"
